@model Usuario
@{
    ViewData["Title"] = "Edição de Usuarios";
}

<h1 class="row justify-content-md-center" >Edição de Usuarios</h1>
<div class="row justify-content-md-center">
    <form asp-action="Editar" method="POST" >
        <fieldset>
            <legend>Usuarios</legend>
            <div class="form-group">
                <label asp-for="Nome">Nome</label>
                <input asp-for="Nome" class="form-control">
            </div>
            <div class="form-group">
                <label asp-for="Login">Login</label>
                <input asp-for="Login" class="form-control">
            </div>
            <div class="form-group">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" class="form-control">
            </div>
            <div class="form-group">
                <label asp-for="Senha">Senha</label>
                <input asp-for="Senha" class="form-control">
            </div>
            <div class="form-group">
                <label>Tipo de Plano</label>
                <select name="tipo">
                    <option value="@Usuario.BASICO">Basico</option>
                    <option value="@Usuario.PESSOAL">Pessoal</option>
                    <option value="@Usuario.EMPRESARIAL">Empresarial</option>
                </select>
            </div>
        </fieldset>
        <input type="number" asp-for="Id">
        <input asp-for="Id" type="hidden">
        <input type="submit" value="Atualizar">
    </form>