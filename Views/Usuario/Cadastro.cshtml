@model Usuario
@{
    ViewData["title"] = "Cadastro de Usuarios";
}

<h1 class="row justify-content-md-center">Cadastro de Usuarios</h1>
<div class="row justify-content-md-center">
    <form asp-action="Cadastro" method="POST" class="coml-md-4">
        <fieldset>
            <legend>Usuarios</legend>
            <div class="form-group">
                <label asp-for="Nome">Nome</label>
                <input asp-for="Nome" required>
            </div>
            <div class="form-group">
                <label asp-for="Login">Login</label>
                <input asp-for="Login" required>
            </div>
            <div class="form-group">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" required>
            </div>
            <div class="form-group">
                <label asp-for="Senha">Senha</label>
                <input asp-for="Senha" required>
            </div>

            <div class="form-group">
                <label>Tipo de Plano</label>
                <select name="tipo">
                    <option value="@Usuario.BASICO">Basico</option>
                    <option value="@Usuario.PESSOAL">Pessoal</option>
                    <option value="@Usuario.EMPRESARIAL">Empresarial</option>
                </select>
            </div>

            @ViewData["mensagem"]
        </fieldset>
        <input type="submit" value="Cadastrar">
    </form>
</div>