@model ICollection<Usuario>
    @{
        ViewData["Title"] = "Listagem de Usuários";
    }

    <div class="row">
        <div class="col-md-12">
            <table class="table">
                <thead>
                    <tr>
                        <td>Id</td>
                        <td>Nome</td>
                        <td>Login</td>
                        <td>E-mail</td>
                    </tr>
                </thead>
                <tbody>
                    @foreach (Usuario u in Model)
                    {
                        <tr>
                            <td>@u.Id</td>
                            <td>@u.Nome</td>
                            <td>@u.Login</td>
                            <td>@u.Email</td>

                            <td><a href="/Usuario/Editar?ID=@u.Id">Editar</a></td>
                            <td><a href="/Usuario/Excluir?ID=@u.Id">Excluir</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>